{
  "name": "repopulse-command-center",
  "version": "0.1.0",
  "description": "AI-assisted project intelligence platform for GitHub repository monitoring.",
  "main": "backend/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node backend/server.js",
    "test": "jest --coverage",
    "test:integration": "cross-env TEST_INTEGRATION=true node --env-file=.env node_modules/jest/bin/jest.js --testPathPattern=tests/integration",
    "db:migrate": "node-pg-migrate -m migrations up",
    "db:migrate:down": "node-pg-migrate -m migrations down",
    "db:migrate:status": "node-pg-migrate -m migrations status"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^4.18.2",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "node-pg-migrate": "^8.0.4",
    "supertest": "^7.0.0"
  }
}
