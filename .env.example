# RepoPulse environment configuration
# Copy this file to .env and set values for your environment.
# .env is gitignored and must never be committed.

# Port the backend server listens on.
# Default: 3000
PORT=3000

# Absolute path to the summary history JSON file.
# Default (test):       OS temp dir (set automatically when NODE_ENV=test)
# Default (dev/prod):   execution/summaryHistory.json
# Override example:     HISTORY_FILE=/var/data/repopulse/summaryHistory.json
HISTORY_FILE=

# Absolute path to a JSON file containing the projects array.
# When unset, the embedded seed data in execution/projects.js is used.
# Override example:     PROJECTS_FILE=/var/data/repopulse/projects.json
PROJECTS_FILE=
