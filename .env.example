# RepoPulse Command Center — Environment Configuration
# Copy this file to .env and fill in values for your environment.
# .env is gitignored and must NEVER be committed.
# Every variable listed here is required unless marked [Optional].

# ─── Server ──────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# Structured log level: trace | debug | info | warn | error
LOG_LEVEL=info

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers.
# Set the Authorization callback URL to match GITHUB_CALLBACK_URL exactly.

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# ─── Token Encryption ────────────────────────────────────────────────────────
# AES-256-GCM key used to encrypt GitHub OAuth access tokens at rest.
# Required. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this value invalidates all stored tokens — users will need to re-login.

TOKEN_ENCRYPTION_KEY=

# ─── Session ─────────────────────────────────────────────────────────────────
# Random secret used to sign session tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SESSION_SECRET=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Required. Primary data store. Format: postgres://user:password@host:port/database
# The server will not start if DATABASE_URL is missing or empty.
# Replace 'password' with the actual password for your local PostgreSQL user.

DATABASE_URL=postgres://repopulse:password@localhost:5432/repopulse_dev

# Test database used when running integration tests (TEST_INTEGRATION=true).
# [Optional] Defaults to repopulse_test on localhost if not set.
TEST_DATABASE_URL=postgres://repopulse:password@localhost:5432/repopulse_test

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used for job queues (Phase 3+). Required from Phase 3 onward.
# [Optional until Phase 3]

REDIS_URL=redis://localhost:6379

# ─── Proactive Alerts ─────────────────────────────────────────────────────────
# Enables automatic Slack and email notifications when a snapshot enters
# Critical alertState or Worsening trend.
# Set ENABLE_PROACTIVE_ALERTS=true to activate. All other fields below are
# optional — only the channels you configure will be used.
# [Optional]

ENABLE_PROACTIVE_ALERTS=false

# Slack — set SLACK_WEBHOOK_URL to send alerts to a Slack channel.
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# SMTP email — set SMTP_HOST and ALERT_EMAIL_TO to send email alerts.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ─── Legacy Settings (pre-MVP ingestion) ─────────────────────────────────────
# These variables support the pre-MVP file-based implementation.
# They will be deprecated as the PostgreSQL-backed MVP progresses.

# GitHub organisation or user whose repos are fetched.
GITHUB_ORG=

# Personal access token for GitHub API calls (read-only scope).
GITHUB_TOKEN=

# Controls data source for legacy ingestion: "file" or "github"
PROJECT_SOURCE=github
