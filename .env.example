# RepoPulse environment configuration
# Copy this file to .env and fill in the values for your environment.
# .env is gitignored and must never be committed.

# Port the backend server listens on.
# Default: 3000
PORT=3000

# --- Data source ---

# Controls whether projects come from the embedded seed ("file") or the GitHub API ("github").
# Default: file
PROJECT_SOURCE=github

# GitHub organisation or user whose repos are fetched.
# Required when PROJECT_SOURCE=github.
GITHUB_ORG=your-org-name

# Personal access token (or fine-grained token with repo read scope).
# Optional — omit for public orgs; needed for private repos or to avoid rate-limit errors.
GITHUB_TOKEN=ghp_...

# --- File paths (optional overrides) ---

# Path where the synced GitHub projects JSON is written and read.
# When PROJECT_SOURCE=github this defaults to execution/projects.json automatically.
# Override only if you need to store the file elsewhere.
# PROJECTS_FILE=/var/data/repopulse/projects.json

# Path to the summary history JSON file.
# Default: execution/summaryHistory.json (or OS temp dir when NODE_ENV=test)
# HISTORY_FILE=/var/data/repopulse/summaryHistory.json

# Path to the per-repo history JSON file.
# Default: execution/repoHistory.json (or OS temp dir when NODE_ENV=test)
# REPO_HISTORY_FILE=/var/data/repopulse/repoHistory.json

# --- Worker settings ---

# Snapshot interval in milliseconds. Default: 3600000 (1 hour)
# SNAPSHOT_INTERVAL_MS=3600000

# Set to "true" to enable the background snapshot worker.
# ENABLE_SNAPSHOT_WORKER=true

# --- Risk scoring thresholds ---

# Repos with last push older than this many days are considered stale. Default: 90
# STALE_DAYS=90

# Repos with last push older than this many days are considered inactive. Default: 30
# INACTIVE_DAYS=30

# Repos with more open issues than this threshold are flagged. Default: 20
# ISSUE_THRESHOLD=20

# --- Proactive alerting ---

# Set to "true" to enable Slack/email notifications on Critical alert state or Worsening trend.
# Default: false (disabled)
# ENABLE_PROACTIVE_ALERTS=true

# Slack incoming webhook URL. Leave blank to skip Slack notifications.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Email address(es) to send alert notifications to. Leave blank to skip email.
# ALERT_EMAIL_TO=oncall@your-org.com

# "From" address used in alert emails.
# ALERT_EMAIL_FROM=repopulse@your-org.com

# SMTP server settings for sending alert emails.
# SMTP_HOST=smtp.your-org.com
# SMTP_PORT=587
# SMTP_USER=repopulse@your-org.com
# SMTP_PASS=your-smtp-password
